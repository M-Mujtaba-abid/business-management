generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sale {
  id           String   @id @default(cuid())
  productName  String
  customerName String?  
  address      String?  
  cost         Float
  soldPrice    Float
  profit       Float
  profitHolder String?  
  createdAt    DateTime // <-- Removed @default(now()) so it expects user input
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}