generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url wali line yahan se delete kar di hai
}

model Sale {
  id          String   @id @default(cuid())
  productName String
  customerName String
  address     String
  cost        Float
  soldPrice   Float
  profit      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}